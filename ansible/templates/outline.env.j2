
# --- Outline core ---
NODE_ENV=production
URL=https://{{ outline_domain }}
SECRET_KEY={{ outline_secret_key }}
UTILS_SECRET={{ outline_utils_secret }}

# --- Database (Azure PostgreSQL) ---
DATABASE_URL=postgres://{{ postgres_user }}:{{ postgres_password | urlencode }}@{{ postgres_fqdn }}:5432/{{ postgres_db }}?sslmode=require
PGSSLMODE=require

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- File storage via S3 (MinIO Azure Gateway) ---
FILE_STORAGE=s3
AWS_S3_BUCKET_NAME=outline
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_UPLOAD_MAX_SIZE=262144000
AWS_S3_ACL=private
AWS_S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID={{ azure_storage_account }}
AWS_SECRET_ACCESS_KEY={{ azure_storage_key }}

# --- OIDC (Azure AD) ---
OIDC_CLIENT_ID={{ oidc_client_id }}
OIDC_CLIENT_SECRET={{ oidc_client_secret }}
OIDC_AUTH_URI=https://login.microsoftonline.com/{{ oidc_tenant_id }}/oauth2/v2.0/authorize
OIDC_TOKEN_URI=https://login.microsoftonline.com/{{ oidc_tenant_id }}/oauth2/v2.0/token
OIDC_USERINFO_URI=https://graph.microsoft.com/oidc/userinfo
OIDC_SCOPES=openid profile email

# --- Misc ---
FORCE_HTTPS=true
LOG_LEVEL=info
